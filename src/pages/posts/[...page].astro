---
import type {GetStaticPaths, Page} from "astro";

import Pagination from "@/components/Paginator.astro";
import PostPreview from "@/components/blog/SanityPostPreview.astro";
import PageLayout from "@/layouts/Base.astro";
import {getAllPostsForListing} from "../../../sanity/lib/posts";
import {loadQuery} from "../../../sanity/lib/load-query";

export const getStaticPaths: GetStaticPaths = async ({paginate}) => {
	const posts = await getAllPostsForListing();
	return paginate(posts, {
		pageSize: 10,
	});
};

interface Props {
	page: Page<Awaited<ReturnType<typeof getAllPostsForListing>>[number]>;
}

const {page} = Astro.props;

// With `[...page].astro`, page 1 is `/posts/` (not `/posts/1`).
if (Astro.params.page === "1") {
	return Astro.redirect("/posts/", 301);
}

// In dev mode, Astro can render non-generated routes (e.g. direct navigation)
// before `paginate()` has produced a matching `page` prop. Provide an SSR fallback
// so `/posts/` never 404s while developing, while still being fully static in build.
let effectivePage = page;
if (!effectivePage && !import.meta.env.PROD) {
	const pageSize = 10;
	const currentPage = Number.parseInt(Astro.params.page ?? "1", 10);
	const safePage = Number.isFinite(currentPage) && currentPage > 0 ? currentPage : 1;
	const start = (safePage - 1) * pageSize;
	const end = safePage * pageSize;

	const countRes = await loadQuery<number>({
		query: `count(*[_type == "post" && defined(slug.current)])`,
	});
	const total = countRes.data ?? 0;
	const lastPage = Math.max(1, Math.ceil(total / pageSize));

	const postsRes = await loadQuery<Array<{_id: string; title: string; slug: string; publishedAt?: string}>>({
		query: `
			*[_type == "post" && defined(slug.current)] | order(publishedAt desc) {
				_id,
				title,
				"slug": slug.current,
				publishedAt,
			}[$start...$end]
		`,
		params: {start, end},
	});
	const data = postsRes.data ?? [];

	effectivePage = {
		data,
		start,
		end,
		size: pageSize,
		total,
		currentPage: safePage,
		lastPage,
		url: {
			current: safePage === 1 ? "/posts/" : `/posts/${safePage}/`,
			prev: safePage > 1 ? (safePage - 1 === 1 ? "/posts/" : `/posts/${safePage - 1}/`) : undefined,
			next: safePage < lastPage ? `/posts/${safePage + 1}/` : undefined,
			first: safePage === 1 ? undefined : "/posts/",
			last: lastPage === 1 ? undefined : `/posts/${lastPage}/`,
		},
	} as any;
}

if (!effectivePage) {
	Astro.response.status = 404;
}

const meta = {
  description: "Ready my collection of posts and the things that interest me",
  title: "Posts",
};

const paginationProps = {
  ...(effectivePage?.url?.prev && {
    prevUrl: {
      text: `← Previous Posts`,
      url: effectivePage.url.prev,
    },
  }),
  ...(effectivePage?.url?.next && {
    nextUrl: {
      text: `Next Posts →`,
      url: effectivePage.url.next,
    },
  }),
};
---

<PageLayout meta={meta}>
  <h1 class="title mb-6">Posts</h1>
  <section aria-label="Blog post list">
    <ul class="space-y-8 text-start">
      {
        (effectivePage?.data ?? []).map((p) => (
          <li class="flex flex-col flex-wrap gap-2 sm:flex-row [&_q]:basis-full">
            <PostPreview as="h2" post={p} />
          </li>
        ))
      }
    </ul>
    <Pagination {...paginationProps} />
  </section>
</PageLayout>
