---
import type { GetStaticPaths } from "astro";

import PostLayout from "@/layouts/SanityPost.astro";
import { urlForImage, urlForSeoImage } from "../../../sanity/lib/image";
import { getAllPostSlugs, getPostBySlug } from "../../../sanity/lib/posts";
import { portableTextToHtml, portableTextToPlainText } from "../../../sanity/lib/portable-text";

export const getStaticPaths = (async () => {
	const slugs = await getAllPostSlugs();
	return slugs.map((slug) => ({ params: { slug } }));
}) satisfies GetStaticPaths;

const slug = Astro.params.slug;
if (!slug) throw new Error("Missing slug param");

const post = await getPostBySlug(slug);

if (!post) {
	throw new Error(`Post not found for slug: ${slug}`);
}

const publishedAt = post.publishedAt ? new Date(post.publishedAt) : undefined;
const html = portableTextToHtml(post.body ?? []);
const descriptionFromBody = portableTextToPlainText(post.body ?? []).slice(0, 160);
const description = descriptionFromBody || post.title;
const ogImage = post.mainImage ? urlForSeoImage(post.mainImage).url() : undefined;
const mainImageUrl = post.mainImage ? urlForImage(post.mainImage).width(1600).fit("max").url() : undefined;
---

<PostLayout
	meta={{ title: post.title, description, ogImage, articleDate: publishedAt?.toISOString() }}
	publishedAt={publishedAt}
	title={post.title}
	mainImageUrl={mainImageUrl}
>
	<Fragment set:html={html} />
</PostLayout>
